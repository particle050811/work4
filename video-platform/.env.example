# FanOne 视频平台 - 本地开发环境配置
# 使用方式：
# 1. 复制当前文件为 .env
# 2. 按本机 MySQL / Redis / JWT 配置修改
# 3. 服务启动时会优先读取当前目录下的 .env

# DB_DSN:
# MySQL 连接串，程序启动时会尝试自动创建数据库。
# 格式示例：
#   用户名:密码@tcp(主机:端口)/数据库名?charset=utf8mb4&parseTime=True&loc=Local
# 本项目默认数据库名建议使用 fanone。
DB_DSN=root:123456@tcp(127.0.0.1:3306)/fanone?charset=utf8mb4&parseTime=True&loc=Local

# REDIS_ADDR:
# Redis 地址。留空表示关闭 Redis 缓存，热榜接口将自动降级为直连数据库。
# 本地开发常用 127.0.0.1:6379。
REDIS_ADDR=127.0.0.1:6379

# REDIS_PASSWORD:
# Redis 密码。无密码请留空，不要写引号。
REDIS_PASSWORD=

# REDIS_DB:
# Redis 逻辑库编号，默认 0。
# 建议本地开发单独使用一个 DB，避免与其他项目互相污染。
REDIS_DB=0

# JWT_SECRET:
# JWT 签名密钥，用户登录、鉴权、刷新令牌都会依赖该值。
# 生产环境必须替换为高强度随机字符串，并妥善保管。
JWT_SECRET=fanone-video-platform-secret-key-2024

# SERVER_PORT:
# Hertz 服务监听端口。
# 默认 8888，对应本地访问地址 http://localhost:8888。
SERVER_PORT=8888
