# FanOne 视频平台 - 本地开发环境配置
# 复制此文件为 .env 并根据实际情况修改

# 数据库配置
DB_DSN=root:123456@tcp(127.0.0.1:3306)/fanone?charset=utf8mb4&parseTime=True&loc=Local

# Redis 配置（可选，不配置则跳过缓存）
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 配置
JWT_SECRET=fanone-video-platform-secret-key-2024

# 服务配置
SERVER_PORT=8888
