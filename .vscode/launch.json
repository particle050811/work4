{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FanOne Video Platform",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/video-platform",
            "cwd": "${workspaceFolder}/video-platform",
            "envFile": "${workspaceFolder}/video-platform/.env",
            "showLog": true
        },
        {
            "name": "E2E Test",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/test",
            "cwd": "${workspaceFolder}/test",
            "env": {
                "BASE_URL": "http://localhost:8888"
            },
            "showLog": true
        }
    ]
}
